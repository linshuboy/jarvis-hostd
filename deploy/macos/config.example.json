{
  "gateway": {
    "ws_url": "ws://127.0.0.1:8001/ws/node",
    "tls_mode": "system"
  },
  "display_name": "macbook-pro",
  "heartbeat_seconds": 20,
  "components": {
    "host": {
      "enabled": true,
      "methods": [
        "host.fs.stat",
        "host.fs.list",
        "host.fs.read",
        "host.fs.write",
        "host.fs.mkdir",
        "host.exec.run",
        "host.update.apply"
      ],
      "update": {
        "command": ["/bin/bash", "/workspace/scripts/apply_container_rollout.sh"],
        "root": "/Users/agi/Library/Application Support/hostd/updates",
        "download": true,
        "timeout_seconds": 1200
      },
      "workspace_hints": [
        {
          "name": "Home",
          "root_path": "/Users/agi"
        },
        {
          "name": "Projects",
          "root_path": "/Users/agi/Projects"
        }
      ]
    }
  },
  "logging": {
    "level": "info"
  }
}
