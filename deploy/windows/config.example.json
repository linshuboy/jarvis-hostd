{
  "gateway": {
    "ws_url": "ws://127.0.0.1:8001/ws/node",
    "tls_mode": "system"
  },
  "display_name": "build-host-windows",
  "heartbeat_seconds": 20,
  "components": {
    "host": {
      "enabled": true,
      "methods": [
        "host.fs.stat",
        "host.fs.list",
        "host.fs.read",
        "host.fs.write",
        "host.fs.mkdir",
        "host.exec.run",
        "host.update.apply"
      ],
      "update": {
        "command": ["powershell.exe", "-ExecutionPolicy", "Bypass", "-File", "C:\\workspace\\scripts\\apply_container_rollout.ps1"],
        "root": "C:\\ProgramData\\hostd\\updates",
        "download": true,
        "timeout_seconds": 1200
      },
      "workspace_hints": [
        {
          "name": "Profile",
          "root_path": "C:\\Users\\agi"
        },
        {
          "name": "Projects",
          "root_path": "C:\\Users\\agi\\Projects"
        }
      ]
    }
  },
  "logging": {
    "level": "info"
  }
}
